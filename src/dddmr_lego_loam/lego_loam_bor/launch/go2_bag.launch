<launch>

  <!-- 建图节点（离线bag模式） -->
  <node pkg="lego_loam_bor" exec="lego_loam_bag" output="screen" respawn="false">
    <param from="$(find-pkg-share lego_loam_bor)/config/mid360_go2_config.yaml" />
    <!-- 强制使用仿真时间，与bag内时间戳同步 -->
    <param name="use_sim_time" value="true" />
  </node>

  <!-- Rviz2 可视化 -->
  <node pkg="rviz2" exec="rviz2" output="screen" respawn="false" 
        args="-d $(find-pkg-share lego_loam_bor)/rviz/lego_loam.rviz">
    <!-- Rviz也要使用仿真时间，否则点云时间戳不匹配 -->
    <param name="use_sim_time" value="true" />
  </node>

  <!-- 静态TF（使用参数形式，避免旧版参数警告，并确保时间戳为0被tf2接受） -->
  <node pkg="tf2_ros" exec="static_transform_publisher" name="sensor2baselink">
    <param name="frame_id" value="base_link"/>
    <param name="child_frame_id" value="livox_frame"/>
    <param name="translation" value="0.1 0 0.11"/>
    <param name="rotation" value="-0.034 0.56395 0"/>
  </node>

  <node pkg="tf2_ros" exec="static_transform_publisher" name="baselink2footprint">
    <param name="frame_id" value="base_link"/>
    <param name="child_frame_id" value="base_footprint"/>
    <param name="translation" value="0.0 0 -0.24"/>
    <param name="rotation" value="0 0 0"/>
  </node>

</launch>